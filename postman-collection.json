			"script": {
				"type": "text/javascript",
				"exec": [
					"// 🎯 Глобальний pre-request скрипт",
					"console.log('🚀 Executing:', pm.request.method, pm.request.url.path.join('/'));",
					"",
				"// Інформація про HTTP-only cookies",
				"console.log('🍪 ОБА токени зберігаються в HTTP-only cookies:');",
				"console.log('  - access_token: автоматично надсилається з кожним запитом');",
				"console.log('  - refresh_token: використовується для оновлення access токена');",
				"console.log('🔒 Токени недоступні JavaScript коду (максимальна безпека)');"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// 🎯 Глобальні тести для всіх запитів",
					"pm.test('Response time < 2s', function () {",
					"    pm.expect(pm.response.responseTime).to.be.below(2000);",
					"});",
					"",
					"pm.test('Content-Type is JSON (if not error)', function () {",
					"    if (![401, 403, 429].includes(pm.response.code)) {",
					"        pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
					"    }",
					"});",
					"",
					"// Логуємо результат запиту",
					"const status = pm.response.code;",
					"const emoji = status < 300 ? '✅' : status < 500 ? '⚠️' : '❌';",
					"console.log(emoji + ' Response: ' + status + ' ' + pm.response.status);"
				]
			}
		}
	]
}