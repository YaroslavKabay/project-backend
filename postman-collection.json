        },
        {
            "name": "📁 3. JWT PROTECTED ROUTES",
            "item": [
                {
                    "name": "✅ Get Profile (JWT Auth)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{access_token}}",
                                "description": "JWT токен автоматично підставляється"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/profile",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "profile"
                            ]
                        },
                        "description": "🎯 **Захищений роут через JWT**\n\n**Що відбувається:**\n1. JwtAuthGuard активує JwtStrategy\n2. JwtStrategy витягує токен з Authorization header\n3. JwtStrategy перевіряє підпис + термін дії\n4. JwtStrategy завантажує user з БД\n5. req.user заповнюється\n6. Controller повертає профіль\n\n**Очікуваний результат:**\n- Status: 200 OK\n- Дані користувача БЕЗ sensitive полів"
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Profile data is returned', function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('id');",
                                    "    pm.expect(jsonData).to.have.property('email');",
                                    "    pm.expect(jsonData).to.have.property('name');",
                                    "    pm.expect(jsonData).to.have.property('role');",
                                    "    pm.expect(jsonData).to.have.property('balance');",
                                    "});",
                                    "",
                                    "pm.test('No sensitive data exposed', function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.not.have.property('passwordHash');",
                                    "    pm.expect(jsonData).to.not.have.property('emailVerificationToken');",
                                    "    pm.expect(jsonData).to.not.have.property('passwordResetToken');",
                                    "});",
                                    "",
                                    "pm.test('Email matches login email', function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.email).to.eql('yarko.test@gmail.com');",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "❌ Profile - No Token",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{baseUrl}}/auth/profile",
                            "host": [
                                "{{baseUrl}}"
                            ],
