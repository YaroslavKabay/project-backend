		{
			"name": "📁 3. PASSWORD RESET SYSTEM 🔄",
			"item": [
				{
					"name": "🔄 Refresh Access Token",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{}"
						},
						"url": {
							"raw": "{{base_url}}/auth/refresh",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"auth",
								"refresh"
							]
						},
						"description": "🔄 **HTTP-ONLY COOKIES: Оновлення access токена**\n\n**Що тестуємо:**\n- Читання refresh токена з HTTP-only cookie\n- Валідацію refresh токена в БД\n- Встановлення НОВОГО access токена в HTTP-only cookie\n- Response БЕЗ токенів в body (максимальна безпека)\n\n**Логи в консолі:**\n- `✅ Access token refreshed successfully for user ID: 1`\n\n**Очікуваний результат:**\n- Status: 200 OK\n- Response: { message, user } (БЕЗ access_token в body!)\n- Cookie: access_token оновлюється автоматично"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200', function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test('Response contains message (NO tokens in body)', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('message');",
									"    pm.expect(jsonData.message).to.be.a('string');",
									"    // ✅ КРИТИЧНО: НЕ має бути токенів в response body",
									"    pm.expect(jsonData).to.not.have.property('access_token');",
									"    pm.expect(jsonData).to.not.have.property('refresh_token');",
									"});",
									"",
									"pm.test('User data returned', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.user).to.have.property('id');",
									"    pm.expect(jsonData.user).to.have.property('email');",
									"});",
									"",
									"// 🍪 HTTP-only cookies керуються автоматично браузером",
									"console.log('🔄 Access token оновлено в HTTP-only cookie (автоматично)');"
								]
							}
						}
					]
				},
