        {
            "name": "📁 4. EDGE CASES & SECURITY",
            "item": [
                {
                    "name": "🔒 Security Test - SQL Injection Email",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"admin'; DROP TABLE users; --\",\n  \"password\": \"HackAttempt123!\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "description": "🎯 **Тест на SQL Injection**\n\n**Очікуваний результат:**\n- Status: 400 Bad Request (DTO валідація)\n- Або 401 Unauthorized (якщо пройшла валідацію)\n- Prisma має захист від SQL Injection"
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('SQL injection blocked', function () {",
                                    "    // Має бути 400 (валідація) або 401 (неправильні дані)",
                                    "    pm.expect([400, 401]).to.include(pm.response.code);",
                                    "});",
                                    "",
                                    "pm.test('No server crash or 500 error', function () {",
                                    "    pm.response.to.not.have.status(500);",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "🔒 Security Test - XSS in Name",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"xss.test@gmail.com\",\n  \"password\": \"ValidPass123!\",\n  \"name\": \"<script>alert('XSS')</script>\",\n  \"surname\": \"Test\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        },
                        "description": "🎯 **Тест на XSS в полі name**\n\n**Очікуваний результат:**\n- Status: 400 Bad Request\n- DTO валідація має заблокувати HTML теги"
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('XSS attempt blocked by validation', function () {",
                                    "    pm.response.to.have.status(400);",
                                    "});",
                                    "",
                                    "pm.test('Validation error mentions invalid characters', function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(JSON.stringify(jsonData)).to.include('літери');",
                                    "});"
                                ]
                            }
                        }
                    ]
                }
            ]
        }
    ],
    "event": [
        {
