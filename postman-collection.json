{
    "info": {
        "name": "Project Backend - Passport Auth API",
        "description": "🚀 Повна колекція для тестування Passport аутентифікації\n\n📝 **Порядок тестування:**\n1. Register - створити акаунт\n2. Login - отримати JWT токен\n3. Profile - перевірити захищений роут\n\n🎯 **Автоматика:**\n- JWT токен автоматично зберігається після login\n- Токен автоматично додається в Authorization header",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string",
            "description": "Base URL сервера"
        },
        {
            "key": "access_token",
            "value": "",
            "type": "string",
            "description": "JWT токен (автоматично оновлюється після login)"
        }
    ],
    "item": [
        {
            "name": "📁 1. РЕЄСТРАЦІЯ",
            "item": [
                {
                    "name": "✅ Register Success",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"yarko.test@gmail.com\",\n  \"password\": \"MyStrongPass123!\",\n  \"name\": \"Ярослав\",\n  \"surname\": \"Тестовий\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/register",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "register"
                            ]
                        },
                        "description": "🎯 **Успішна реєстрація**\n\n**Очікуваний результат:**\n- Status: 201 Created\n- Користувач створений в БД\n- Пароль захешований"
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 201', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test('Response has success message', function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.message).to.include('успішно');",
                                    "});",
                                    "",
                                    "pm.test('User data is returned', function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.user).to.have.property('id');",
                                    "    pm.expect(jsonData.user).to.have.property('email');",
                                    "    pm.expect(jsonData.user).to.not.have.property('passwordHash');",
                                    "});"
                                ]
                            }
                        }
                    ]
                },
