				{
					"name": "✅ Register Success",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"test.user@gmail.com\",\n  \"password\": \"SecurePass123!\",\n  \"name\": \"Тестовий\",\n  \"surname\": \"Користувач\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/register",
							"host": ["{{base_url}}"],
							"path": ["auth", "register"]
						},
						"description": "🎯 **Успішна реєстрація + автологін**\n\n**Очікуваний результат:**\n- Status: 201 Created\n- Повертає access_token (2h) + refresh_token (14d)\n- Користувач автоматично залогінений\n- Токени зберігаються автоматично"
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response has both tokens', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('access_token');",
									"    pm.expect(jsonData).to.have.property('refresh_token');",
									"    pm.expect(jsonData.access_token).to.be.a('string');",
									"    pm.expect(jsonData.refresh_token).to.be.a('string');",
									"});",
									"",
									"pm.test('User data returned without sensitive fields', function () {",
									"    const jsonData = pm.response.json();",
									"    pm.expect(jsonData.user).to.have.property('id');",
									"    pm.expect(jsonData.user).to.have.property('email');",
									"    pm.expect(jsonData.user).to.not.have.property('passwordHash');",
									"});",
									"",
									"// 🎯 АВТОМАТИЧНО ЗБЕРІГАЄМО ТОКЕНИ",
									"const jsonData = pm.response.json();",
									"if (jsonData.access_token && jsonData.refresh_token) {",
									"    pm.collectionVariables.set('access_token', jsonData.access_token);",
									"    pm.collectionVariables.set('refresh_token', jsonData.refresh_token);",
									"    console.log('✅ Токени збережені після реєстрації');",
									"}"
								]
							}
						}
					]
