        {
            "name": "📁 2. PASSPORT LOGIN",
            "item": [
                {
                    "name": "✅ Login Success (Passport)",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"yarko.test@gmail.com\",\n  \"password\": \"MyStrongPass123!\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/auth/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "login"
                            ]
                        },
                        "description": "🎯 **Успішний логін через Passport LocalStrategy**\n\n**Що відбувається:**\n1. LocalAuthGuard активує LocalStrategy\n2. LocalStrategy перевіряє email/password\n3. AuthService генерує JWT токен\n\n**Очікуваний результат:**\n- Status: 200 OK\n- JWT токен в відповіді\n- Токен автоматично зберігається"
                    },
                    "response": [],
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "type": "text/javascript",
                                "exec": [
                                    "pm.test('Status code is 200', function () {",
                                    "    pm.response.to.have.status(200);",
                                    "});",
                                    "",
                                    "pm.test('Response has access token', function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData).to.have.property('access_token');",
                                    "    pm.expect(jsonData.access_token).to.be.a('string');",
                                    "    pm.expect(jsonData.access_token.length).to.be.above(50);",
                                    "});",
                                    "",
                                    "pm.test('User data is returned', function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.user).to.have.property('id');",
                                    "    pm.expect(jsonData.user).to.have.property('email');",
                                    "    pm.expect(jsonData.user.email).to.eql('yarko.test@gmail.com');",
                                    "});",
                                    "",
                                    "// 🎯 АВТОМАТИЧНО ЗБЕРІГАЄМО JWT ТОКЕН",
                                    "const jsonData = pm.response.json();",
                                    "if (jsonData.access_token) {",
                                    "    pm.collectionVariables.set('access_token', jsonData.access_token);",
                                    "    console.log('✅ JWT токен збережений:', jsonData.access_token.substring(0, 50) + '...');",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
